VITE_API_URL=https://ccd-api.initdevelopment.com
VITE_DIRECTUS_URL=url
VITE_DIRECTUS_TOKEN=token

# Storage type ID the client sends on upload: 1 = filesystem, 2 = Azure Blob
VITE_STORAGE_TYPE_ID=1

# Authentication provider: "local" (default) or "b2c"
VITE_AUTH_PROVIDER=local

# Azure AD B2C settings (required when VITE_AUTH_PROVIDER=b2c)
VITE_B2C_TENANT=
VITE_B2C_CLIENT_ID=
VITE_B2C_USER_FLOW=
VITE_B2C_REDIRECT_URI=
